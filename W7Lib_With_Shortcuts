            ActiveShortcuts[name]:Destroy()
            ActiveShortcuts[name] = nil
            return
        end

        Config.Shortcuts[name] = Config.Shortcuts[name] or {}

        local frame = Instance.new("Frame")
        frame.Name = "Shortcut_" .. name
        frame.Size = UDim2.new(0, 120, 0, 56)
        frame.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
        frame.Active = true
        frame.Parent = ShortcutGui

        local savedPos = Config.Shortcuts[name].pos
        if savedPos then
            frame.Position = UDim2.new(savedPos[1], savedPos[2], savedPos[3], savedPos[4])
        else
            frame.Position = UDim2.new(0.5, -60, 0.5, -28)
        end

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 10)
