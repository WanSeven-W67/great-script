        end
        RefreshVisual()

        clickBtn.MouseButton1Click:Connect(function()
            PlayClickSound()
            toggleFn()
            RefreshVisual()
        end)

        MakeDraggable(frame, name)
        ActiveShortcuts[name] = frame
    end

    -- Dipasang ke Frame apapun (misalnya ToggleFrame) supaya tap/klik TAHAN 0.5 detik
    -- munculin/hilangin mini shortcut button-nya. Jalan otomatis di HP (jari) & PC (mouse).
    local function AttachLongPressShortcut(hostFrame, name, icon, isOnFn, toggleFn)
        local pressToken = nil
        local longPressFired = false

        hostFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                local myToken = {}
                pressToken = myToken
                longPressFired = false
                task.delay(0.5, function()
                    if pressToken == myToken then
                        longPressFired = true
                        ToggleShortcutButton(name, icon, isOnFn, toggleFn)
                    end
                end)
            end
        end)

        hostFrame.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pressToken = nil
            end
        end)

        -- dipanggil oleh tombol utama (mis. Switch) supaya tau apakah harus skip klik normal
        return function()
            if longPressFired then
                longPressFired = false
                return true -- skip klik normal
            end
            return false
        end
    end

